# Deployer wallet — pays gas for contract deployment. NEVER commit the real value.
DEPLOYER_PRIVATE_KEY=

# RPC endpoints
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Block explorer verification
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# SMLYieldBondFactory constructor arg — where the 0.5% protocol fee on each
# closed funding round is sent. This must be a real address you control
# before running any deploy:* script; it is not set anywhere by default.
PROTOCOL_TREASURY_ADDRESS=

# ── x402 Settlement Router ──────────────────────────────────────────────────
# See scripts/deploy-settlement-router.ts, scripts/create-router.ts,
# scripts/update-reputation-oracle.ts. PROTOCOL_TREASURY_ADDRESS above is
# reused as FeeRegistry's treasury — must be a Gnosis Safe multisig, not an EOA.

# Settlement token. Defaults to canonical USDC on Base / Base Sepolia if
# unset — see DEFAULT_USDC in scripts/deploy-settlement-router.ts. Required
# on any other network.
TOKEN_ADDRESS=

# Initial protocol fee in basis points. Default 50 (0.5%). Hard-capped at
# 500 (5%) on-chain by FeeRegistry — no governance path can exceed this.
PROTOCOL_FEE_BPS=50

# Signer authorized to push ARGUS/402Proof scores into ReputationOracle.
# scripts/update-reputation-oracle.ts signs with this address's key.
REPUTATION_UPDATER_ADDRESS=

# The address SettlementRouter.onlyOrchestrator trusts to call
# createTask/settleTask/slashAgent — the signer the off-chain netting
# engine (../src/settlement-router/) signs with. Not an end-user wallet.
ORCHESTRATOR_ADDRESS=

# Base URL of the deployed src/squeezeos-server.ts instance that serves
# GET /api/credit-score. No default — this repo's render.yaml does not
# currently define a service for that entry point (only
# start:vending-router and start:asc-orchestrator are deployed). Find the
# real URL before running scripts/update-reputation-oracle.ts.
SQUEEZEOS_MCP_BASE_URL=

# Path to a JSON file mapping ARGUS agentDid -> Base wallet address, e.g.
# [{"agentDid":"did:key:z6Mk...","agentAddress":"0xabc..."}]. Required by
# scripts/update-reputation-oracle.ts — no such mapping exists elsewhere
# in this codebase yet (ARGUS is keyed by DID, TaskEscrow by address).
AGENT_DID_MAP_PATH=
