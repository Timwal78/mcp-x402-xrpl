{
  "name": "@scriptmasterlabs/sml-asc-contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Solidity contracts and deployment scripts for the SML Autonomous Software Corporation (ASC) yield-bond funding layer.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
