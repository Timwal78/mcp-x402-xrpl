    "deploy-bond:base": "hardhat run scripts/deploy-bond.ts --network base"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.10",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2",
    "dotenv": "^16.4.5"
  }
}
