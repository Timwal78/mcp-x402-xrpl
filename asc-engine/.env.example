# ── Chain config — all three required for the orchestrator to do anything ──
BASE_RPC_URL=https://mainnet.base.org
ORCHESTRATOR_PRIVATE_KEY=
BOND_CONTRACT_ADDRESS=

# ── BYOK LLM reasoning (optional) ───────────────────────────────────────────
# Unset = deterministic pattern-matching mode, zero API cost.
# Set = real Claude reasoning per agent role, billed to this key directly.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# ── Autonomous "set and forget" CEO loop (optional, requires the above) ────
ASC_AUTONOMOUS=false
ASC_CEO_INTERVAL_MS=600000

PORT=3404
