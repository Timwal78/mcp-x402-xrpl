{
  "name": "@scriptmasterlabs/mcp-x402",
  "version": "2.1.1",
  "description": "x402 HTTP payment middleware for MCP servers — XRPL, Xahau, XAH, RLUSD settlement. Drop-in autonomous agent payment rails. No custodians, no API keys.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/squeezeos-server.ts",
    "start:vending-router": "tsx src/vending-router-server.ts",
    "generate:manifest": "tsx scripts/generate-manifest.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "example:pay-per-tool": "node examples/pay-per-tool.js",
    "leviathan": "node dist/acp/leviathan.js",
    "leviathan:dev": "tsx src/acp/leviathan.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "x402",
    "xrpl",
    "xahau",
    "xah",
    "rlusd",
    "http-402",
    "payment-required",
    "ai-agents",
    "autonomous-agents",
    "model-context-protocol",
    "agentic-commerce",
    "machine-to-machine-payments",
    "crypto-payments",
    "geo",
    "scriptmasterlabs"
  ],
  "author": "ScriptMasterLabs <hello@scriptmasterlabs.com> (https://scriptmasterlabs.com)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Timwal78/mcp-x402-xrpl#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Timwal78/mcp-x402-xrpl.git"
  },
  "bugs": {
    "url": "https://github.com/Timwal78/mcp-x402-xrpl/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.47.10",
    "@virtuals-protocol/acp-node-v2": "^0.1.6",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "tsx": "^4.19.2",
    "xrpl": "^3.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "schema.jsonld",
    ".well-known/",
    "llms.txt",
    "README.md",
    "LICENSE"
  ]
